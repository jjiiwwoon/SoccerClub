<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- 기본 앱 테마 -->
    <style name="Theme.SoccerClub" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">#E8EFF8</item>
    </style>

    <!-- 로그인 화면 전용 (흰 화면 깜빡임 방지) -->
    <style name="Theme.SoccerClub.Login" parent="Theme.SoccerClub">
        <item name="android:windowBackground">@drawable/login_background</item>
    </style>

    <!-- 스플래시 실제 콘텐츠 화면 전용 (시스템 스플래시 종료 직후 즉시 이 배경으로 시작) -->
    <style name="Theme.SoccerClub.SplashContent" parent="Theme.SoccerClub">
        <item name="android:windowBackground">@drawable/splash_illustration</item>
    </style>

    <!-- 시스템 스플래시(SplashScreen API) 전용 -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg_top</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.SoccerClub.SplashContent</item>
    </style>

</resources>