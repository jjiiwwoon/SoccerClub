<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="@dimen/spacing_md"
    android:background="@drawable/bg_card"
    android:layout_marginHorizontal="@dimen/spacing_sm"
    android:layout_marginBottom="@dimen/spacing_sm">

    <ImageView
        android:id="@+id/teamLogo"
        android:layout_width="@dimen/avatar_sm"
        android:layout_height="@dimen/avatar_sm"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_shield_gray"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="@dimen/spacing_md">

        <TextView
            android:id="@+id/teamName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_lg"
            android:textStyle="bold"
            android:textColor="@color/text_primary"/>

        <TextView
            android:id="@+id/teamRegion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/text_secondary"/>

        <TextView
            android:id="@+id/teamSkillAge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/text_hint"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnProposeMatch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="시합 제안"
        android:textAllCaps="false"
        android:textSize="@dimen/text_sm"
        android:textColor="@color/white"
        android:backgroundTint="@color/primary"
        android:visibility="gone"/>

</LinearLayout>