<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="6dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/bg_divider"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/bg_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- 팀 로고 -->
        <ImageView
            android:id="@+id/teamLogo"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_rounded_rect_12"
            android:clipToOutline="true"
            android:src="@drawable/ic_shield_gray"/>

        <!-- 팀 정보 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/teamName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/teamRegion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/teamSkillAge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- 시합 제안 버튼 -->
        <Button
            android:id="@+id/btnProposeMatch"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:paddingHorizontal="14dp"
            android:text="시합 제안"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/primary"
            android:stateListAnimator="@null"
            android:visibility="gone"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>