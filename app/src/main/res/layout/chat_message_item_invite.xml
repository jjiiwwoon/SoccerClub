<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- 초대 메시지 카드 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:padding="12dp"
        android:maxWidth="260dp">

        <!-- 초대 아이콘 + 텍스트 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_shield_gray"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="[팀 초대] 우리 팀에 합류해보세요!"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- 수락/거절 버튼 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAcceptInvite"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="수락"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:backgroundTint="@color/primary"
                app:cornerRadius="8dp"/>

            <Button
                android:id="@+id/btnRejectInvite"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="거절"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:textColor="@color/loss"
                android:backgroundTint="@color/bg_surface"
                app:strokeColor="@color/loss"
                app:strokeWidth="1dp"
                app:cornerRadius="8dp"/>
        </LinearLayout>

        <!-- 수락/거절 후 상태 표시 -->
        <TextView
            android:id="@+id/tvInviteStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="6dp"
            android:visibility="gone"/>

        <!-- 시간 -->
        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:layout_marginTop="4dp"/>
    </LinearLayout>
</LinearLayout>