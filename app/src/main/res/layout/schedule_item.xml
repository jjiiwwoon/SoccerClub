<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="@dimen/card_padding"
    android:layout_marginHorizontal="@dimen/spacing_sm"
    android:layout_marginBottom="@dimen/spacing_sm">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/text_lg"
        android:textStyle="bold"
        android:textColor="@color/text_primary"/>

    <TextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xs"
        android:textSize="@dimen/text_sm"
        android:textColor="@color/text_secondary"/>

    <TextView
        android:id="@+id/tvOpponent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/text_sm"
        android:textColor="@color/text_secondary"/>

    <TextView
        android:id="@+id/tvStadium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/text_sm"
        android:textColor="@color/text_hint"/>

    <TextView
        android:id="@+id/tvAddress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="@dimen/text_xs"
        android:textColor="@color/text_hint"
        android:singleLine="true"
        android:ellipsize="end"/>

    <!-- 버튼 행 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/spacing_sm">

        <!-- ✅ 참석 투표 버튼 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVoteAttendance"
            android:layout_width="0dp"
            android:layout_height="@dimen/btn_height"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/spacing_xs"
            android:text="참석 투표"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:backgroundTint="@color/primary"
            app:cornerRadius="@dimen/btn_radius"/>

        <!-- 기록하기 버튼 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWriteRecord"
            android:layout_width="0dp"
            android:layout_height="@dimen/btn_height"
            android:layout_weight="1"
            android:text="기록하기"
            android:textAllCaps="false"
            android:textColor="@color/primary"
            android:backgroundTint="@color/bg_surface"
            app:strokeColor="@color/primary"
            app:strokeWidth="1dp"
            app:cornerRadius="@dimen/btn_radius"/>

    </LinearLayout>

</LinearLayout>