<?xml version="1.0" encoding="utf-8"?>
<!-- Capstone 스타일: pill 탭 + 구분된 필터 영역 -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ★ 상단 탭 (Pill 스타일) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:background="@color/bg_surface">

            <TextView
                android:id="@+id/btnRecruitTab"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="모집"
                android:textSize="@dimen/text_md"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:background="@drawable/bg_tab_pill_selected"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btnMatchTab"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="시합"
                android:textSize="@dimen/text_md"
                android:textColor="@color/text_hint"
                android:background="@drawable/bg_tab_pill_unselected"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"/>

            <!-- 신청 목록 버튼 + 뱃지 -->
            <FrameLayout
                android:id="@+id/btnApplicationsList"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_filter_button"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="@dimen/icon_md"
                    android:layout_height="@dimen/icon_md"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_list"/>

                <View
                    android:id="@+id/badgeNewApplications"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_badge_red_circle"
                    android:visibility="gone"/>
            </FrameLayout>
        </LinearLayout>

        <!-- 하위 탭 (시합글 / 팀 매칭) -->
        <LinearLayout
            android:id="@+id/matchModeTabsCard"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:background="@color/bg_section"
            android:visibility="gone">

            <TextView
                android:id="@+id/btnMatchListTab"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="시합글"
                android:textSize="@dimen/text_md"
                android:textColor="@color/primary"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btnTeamMatchTab"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="팀 매칭"
                android:textSize="@dimen/text_md"
                android:textColor="@color/text_hint"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- ★ 필터 바 (Capstone 스타일) -->
        <LinearLayout
            android:id="@+id/filterBarContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/bg_surface"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp">

            <!-- 필터 아이콘 + 텍스트 -->
            <LinearLayout
                android:id="@+id/btnOpenFilter"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:background="@drawable/bg_filter_button"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_filter"
                    android:tint="@color/primary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="필터"
                    android:textSize="13sp"
                    android:textColor="@color/primary"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <!-- 선택된 필터 칩 -->
            <HorizontalScrollView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/selectedFilterChips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"/>
            </HorizontalScrollView>
        </LinearLayout>

        <!-- 팀 찾기 버튼 -->
        <Button
            android:id="@+id/btnTeamFindGlobal"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="팀 찾기 조건 설정"
            android:textAllCaps="false"
            android:textColor="@color/primary"
            android:backgroundTint="@color/primary_light"
            android:visibility="gone"/>

        <!-- 프래그먼트 컨테이너 -->
        <FrameLayout
            android:id="@+id/recruit_match_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
    </LinearLayout>

    <!-- Speed Dial 스크림 -->
    <View
        android:id="@+id/speedDialScrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:visibility="gone"/>

    <!-- Speed Dial 액션: 아이콘 + 텍스트 -->
    <LinearLayout
        android:id="@+id/speedDialActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="80dp"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/btnActionRecruit"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:gravity="center"
            android:background="@drawable/bg_speed_action"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_person_add"
                android:tint="#000000"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="선수 모집"
                android:textSize="13sp"
                android:textColor="#000000"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnActionMatch"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:gravity="center"
            android:background="@drawable/bg_speed_action"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_soccer"
                android:tint="#000000"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="시합 모집"
                android:textSize="13sp"
                android:textColor="#000000"/>
        </LinearLayout>
    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabSpeedDial"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/spacing_lg"
        app:srcCompat="@drawable/ic_add_white"
        app:backgroundTint="@color/primary"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>