<?xml version="1.0" encoding="utf-8"?>
<com.jjw.soccerclub.common.StateLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/stateLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:loadingLayout="@layout/view_state_loading"
    app:emptyLayout="@layout/view_state_empty"
    android:background="@color/bg_page">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 팀 사진 -->
            <ImageView
                android:id="@+id/teamPhoto"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:src="@drawable/default_team_photo"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/page_padding_horizontal">

                <!-- 로고 + 팀명 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/spacing_md">

                    <ImageView
                        android:id="@+id/teamLogo"
                        android:layout_width="@dimen/avatar_md"
                        android:layout_height="@dimen/avatar_md"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_shield_gray"/>

                    <TextView
                        android:id="@+id/teamName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:textSize="@dimen/text_xxl"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>

                <!-- 지역/나이/실력 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="@dimen/spacing_sm">

                    <TextView
                        android:id="@+id/teamRegion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_md"
                        android:textColor="@color/text_secondary"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text=" · " android:textColor="@color/text_hint"/>

                    <TextView
                        android:id="@+id/teamAge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_md"
                        android:textColor="@color/text_secondary"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text=" · 실력 " android:textColor="@color/text_hint"/>

                    <TextView
                        android:id="@+id/teamSkill"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_md"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <!-- 활동요일 -->
                <TextView android:id="@+id/teamActivityDay"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="@dimen/text_sm" android:textColor="@color/text_hint"
                    android:layout_marginTop="@dimen/spacing_xs" android:visibility="gone"/>

                <!-- 구장 -->
                <TextView android:id="@+id/teamHomeStadiumName"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="@dimen/text_sm" android:textColor="@color/text_hint"
                    android:visibility="gone"/>
                <TextView android:id="@+id/teamHomeStadiumAddress"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="@dimen/text_sm" android:textColor="@color/text_hint"
                    android:visibility="gone"/>

                <!-- 구분선 -->
                <View android:layout_width="match_parent" android:layout_height="@dimen/divider_height"
                    android:background="@color/bg_divider"
                    android:layout_marginVertical="@dimen/spacing_md"/>

                <!-- 소개 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/teamIntro"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="@dimen/text_md"
                        android:textColor="@color/text_secondary"
                        android:maxLines="10"
                        android:ellipsize="end"/>

                    <ImageView
                        android:id="@+id/introToggle"
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_arrow_down"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- 구분선 -->
                <View android:layout_width="match_parent" android:layout_height="@dimen/divider_height"
                    android:background="@color/bg_divider"
                    android:layout_marginVertical="@dimen/spacing_md"/>

                <!-- 전적 -->
                <LinearLayout android:id="@+id/recordSection"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="팀 전적"
                            android:textStyle="bold" android:textSize="@dimen/text_lg"
                            android:textColor="@color/text_primary"/>
                        <TextView android:id="@+id/tvSeeDetails"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="상세보기" android:textSize="@dimen/text_sm"
                            android:textColor="@color/primary"
                            android:clickable="true" android:focusable="true"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="@dimen/spacing_sm">
                        <TextView android:id="@+id/tvGames" style="@style/RecordCellValue" android:text="0"/>
                        <TextView android:id="@+id/tvWins" style="@style/RecordCellValue" android:text="0"/>
                        <TextView android:id="@+id/tvDraws" style="@style/RecordCellValue" android:text="0"/>
                        <TextView android:id="@+id/tvLosses" style="@style/RecordCellValue" android:text="0"/>
                        <TextView android:id="@+id/tvGF" style="@style/RecordCellValue" android:text="0"/>
                        <TextView android:id="@+id/tvGA" style="@style/RecordCellValue" android:text="0"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView style="@style/RecordCellHeader" android:text="경기"/>
                        <TextView style="@style/RecordCellHeader" android:text="승"/>
                        <TextView style="@style/RecordCellHeader" android:text="무"/>
                        <TextView style="@style/RecordCellHeader" android:text="패"/>
                        <TextView style="@style/RecordCellHeader" android:text="득점"/>
                        <TextView style="@style/RecordCellHeader" android:text="실점"/>
                    </LinearLayout>

                    <TextView android:id="@+id/tvWinRate"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:textSize="@dimen/text_sm" android:textColor="@color/text_hint"/>
                </LinearLayout>

                <!-- 구분선 -->
                <View android:layout_width="match_parent" android:layout_height="@dimen/divider_height"
                    android:background="@color/bg_divider"
                    android:layout_marginVertical="@dimen/spacing_md"/>

                <!-- 멤버 -->
                <TextView android:id="@+id/tvMemberTitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="팀 멤버" android:textStyle="bold"
                    android:textSize="@dimen/text_lg" android:textColor="@color/text_primary"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewMembers"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:nestedScrollingEnabled="false"/>

                <LinearLayout android:id="@+id/playerListLayout"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical"/>

                <!-- 가입 버튼 -->
                <TextView
                    android:id="@+id/btnJoinTeam"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/btn_height"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:layout_marginBottom="@dimen/spacing_xl"
                    android:background="@drawable/bg_button_rounded"
                    android:gravity="center"
                    android:text="팀 가입 신청"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_lg"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</com.jjw.soccerclub.common.StateLayout>