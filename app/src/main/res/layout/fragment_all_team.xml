<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page">

    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 검색창 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_md"
            android:gravity="center_vertical"
            android:background="@color/bg_surface">

            <EditText
                android:id="@+id/editTeamSearch"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_searchbox"
                android:hint="팀 이름 검색"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_md"
                android:paddingHorizontal="@dimen/spacing_md"
                android:singleLine="true"
                android:imeOptions="actionSearch"/>
        </LinearLayout>

        <!-- 필터 바 -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:background="@color/bg_surface">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/spacing_md">

                <!-- 지역(시) -->
                <LinearLayout
                    android:id="@+id/btnCity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_filter_chip_selector"
                    android:paddingHorizontal="@dimen/chip_padding_horizontal"
                    android:paddingVertical="@dimen/chip_padding_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="@dimen/spacing_sm">

                    <TextView
                        android:id="@+id/textCity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="전체"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_sm"/>

                    <ImageView
                        android:layout_width="@dimen/icon_sm"
                        android:layout_height="@dimen/icon_sm"
                        android:src="@drawable/ic_arrow_down"
                        android:layout_marginStart="@dimen/spacing_xs"/>
                </LinearLayout>

                <!-- 지역(구) -->
                <LinearLayout
                    android:id="@+id/btnDistrict"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_filter_chip_selector"
                    android:paddingHorizontal="@dimen/chip_padding_horizontal"
                    android:paddingVertical="@dimen/chip_padding_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="@dimen/spacing_sm">

                    <TextView
                        android:id="@+id/textDistrict"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="전체"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_sm"/>

                    <ImageView
                        android:layout_width="@dimen/icon_sm"
                        android:layout_height="@dimen/icon_sm"
                        android:src="@drawable/ic_arrow_down"
                        android:layout_marginStart="@dimen/spacing_xs"/>
                </LinearLayout>

                <!-- 실력 -->
                <LinearLayout
                    android:id="@+id/btnSkill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_filter_chip_selector"
                    android:paddingHorizontal="@dimen/chip_padding_horizontal"
                    android:paddingVertical="@dimen/chip_padding_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="@dimen/spacing_sm">

                    <TextView
                        android:id="@+id/textSkill"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="전체"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_sm"/>

                    <ImageView
                        android:layout_width="@dimen/icon_sm"
                        android:layout_height="@dimen/icon_sm"
                        android:src="@drawable/ic_arrow_down"
                        android:layout_marginStart="@dimen/spacing_xs"/>
                </LinearLayout>

                <!-- 나이 시작 -->
                <LinearLayout
                    android:id="@+id/btnAgeStart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_filter_chip_selector"
                    android:paddingHorizontal="@dimen/chip_padding_horizontal"
                    android:paddingVertical="@dimen/chip_padding_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="@dimen/spacing_xs">

                    <TextView
                        android:id="@+id/textAgeStart"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="전체"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_sm"/>

                    <ImageView
                        android:layout_width="@dimen/icon_sm"
                        android:layout_height="@dimen/icon_sm"
                        android:src="@drawable/ic_arrow_down"
                        android:layout_marginStart="@dimen/spacing_xs"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="~"
                    android:textColor="@color/text_hint"
                    android:layout_marginHorizontal="@dimen/spacing_xs"/>

                <!-- 나이 끝 -->
                <LinearLayout
                    android:id="@+id/btnAgeEnd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_filter_chip_selector"
                    android:paddingHorizontal="@dimen/chip_padding_horizontal"
                    android:paddingVertical="@dimen/chip_padding_vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/textAgeEnd"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="전체"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_sm"/>

                    <ImageView
                        android:layout_width="@dimen/icon_sm"
                        android:layout_height="@dimen/icon_sm"
                        android:src="@drawable/ic_arrow_down"
                        android:layout_marginStart="@dimen/spacing_xs"/>
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- 팀 목록 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewTeams"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:padding="@dimen/spacing_xs"/>

    </LinearLayout>

    <!-- FAB 팀 만들기 -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnCreateTeam"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="@dimen/spacing_lg"
        app:srcCompat="@drawable/ic_add_white"
        app:backgroundTint="@color/primary"/>

</RelativeLayout>