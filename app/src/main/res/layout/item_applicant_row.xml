<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="@dimen/spacing_sm"
    android:background="@color/bg_surface">

    <!-- ★ 프로필 사진 (원형) -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imageApplicantLogo"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_person_placeholder"
        app:shapeAppearanceOverlay="@style/CircleImageStyle"
        app:strokeWidth="1dp"
        app:strokeColor="@color/bg_divider"/>

    <!-- 이름 + 실력 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginHorizontal="@dimen/spacing_sm">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/textApplicantRowNew"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEW"
                android:textSize="@dimen/text_xs"
                android:textColor="@color/white"
                android:background="@drawable/bg_badge_red_circle"
                android:paddingHorizontal="@dimen/spacing_xs"
                android:layout_marginEnd="@dimen/spacing_xs"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/textApplicantName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_md"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>
        </LinearLayout>

        <TextView
            android:id="@+id/textApplicantSkill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/text_secondary"/>
    </LinearLayout>

    <!-- ★ 수락 버튼: 투명 배경 + 파란 테두리 + 파란 글씨 -->
    <Button
        android:id="@+id/btnAccept"
        android:layout_width="wrap_content"
        android:layout_height="34dp"
        android:minWidth="56dp"
        android:minHeight="0dp"
        android:gravity="center"
        android:text="수락"
        android:textAllCaps="false"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#1E88E5"
        android:background="@drawable/bg_btn_outline_blue"
        android:paddingHorizontal="14dp"
        android:paddingVertical="0dp"
        android:layout_marginEnd="6dp"/>

    <!-- ★ 거절 버튼: 투명 배경 + 빨간 테두리 + 빨간 글씨 -->
    <Button
        android:id="@+id/btnReject"
        android:layout_width="wrap_content"
        android:layout_height="34dp"
        android:minWidth="56dp"
        android:minHeight="0dp"
        android:gravity="center"
        android:text="거절"
        android:textAllCaps="false"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#E53935"
        android:background="@drawable/bg_btn_outline_red"
        android:paddingHorizontal="14dp"
        android:paddingVertical="0dp"/>

</LinearLayout>