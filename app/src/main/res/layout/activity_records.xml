<?xml version="1.0" encoding="utf-8"?>
<com.jjw.soccerclub.common.StateLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/stateLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:loadingLayout="@layout/view_state_loading"
    app:emptyLayout="@layout/view_state_empty"
    android:background="#E8EFF8">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp">

            <!-- ── 팀 전적 요약 카드 ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/bg_divider"
                app:cardBackgroundColor="@color/bg_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="팀기록"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="14dp"/>

                    <!-- 경기/승/무/패/승률 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="경기" android:textSize="12sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/tvGames" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="승" android:textSize="12sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/tvWins" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="#2E7D32"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="무" android:textSize="12sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/tvDraws" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/text_secondary"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="패" android:textSize="12sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/tvLosses" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="#C62828"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="승률" android:textSize="12sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/tvWinRate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/primary"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/bg_divider" android:layout_marginBottom="12dp"/>

                    <!-- 팀 득실 기록 -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="팀 득실 기록" android:textSize="12sp" android:textColor="@color/text_hint" android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="득점" android:textSize="12sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/tvTotalGoalsFor" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="#1565C0"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="실점" android:textSize="12sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/tvTotalGoalsAgainst" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="#C62828"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="득실차" android:textSize="12sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/tvGoalDiff" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── 개인기록 섹션 헤더 ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="개인기록"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"/>

            <!-- ── 득점 TOP3 + 도움 TOP3 나란히 ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- 득점 TOP3 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/bg_divider"
                    app:cardBackgroundColor="@color/bg_surface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="득점 TOP3" android:textSize="13sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" android:layout_marginBottom="8dp"/>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="bottom">

                            <!-- 2위 -->
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                                android:layout_marginTop="12dp">
                                <ImageView android:layout_width="18dp" android:layout_height="12dp"
                                    android:src="@drawable/crown_silver" android:layout_marginBottom="2dp"/>
                                <com.google.android.material.imageview.ShapeableImageView
                                    android:id="@+id/imageTop2" android:layout_width="36dp" android:layout_height="36dp"
                                    android:scaleType="centerCrop" android:src="@drawable/ic_person_placeholder"
                                    app:shapeAppearanceOverlay="@style/CircleImageStyle"/>
                                <TextView android:id="@+id/tvTop2Name" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:textSize="11sp"
                                    android:textColor="@color/text_primary" android:layout_marginTop="3dp"
                                    android:maxLines="1" android:ellipsize="end"/>
                                <TextView android:id="@+id/tvTop2Goals" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:textSize="11sp"
                                    android:textColor="@color/text_hint"/>
                            </LinearLayout>

                            <!-- 1위 -->
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                                <ImageView android:layout_width="22dp" android:layout_height="14dp"
                                    android:src="@drawable/crown_gold" android:layout_marginBottom="2dp"/>
                                <com.google.android.material.imageview.ShapeableImageView
                                    android:id="@+id/imageTop1" android:layout_width="44dp" android:layout_height="44dp"
                                    android:scaleType="centerCrop" android:src="@drawable/ic_person_placeholder"
                                    app:shapeAppearanceOverlay="@style/CircleImageStyle"/>
                                <TextView android:id="@+id/tvTop1Name" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:textSize="12sp"
                                    android:textStyle="bold" android:textColor="@color/text_primary"
                                    android:layout_marginTop="3dp" android:maxLines="1" android:ellipsize="end"/>
                                <TextView android:id="@+id/tvTop1Goals" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:textSize="12sp"
                                    android:textColor="@color/text_secondary"/>
                            </LinearLayout>

                            <!-- 3위 -->
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                                android:layout_marginTop="16dp">
                                <ImageView android:layout_width="16dp" android:layout_height="10dp"
                                    android:src="@drawable/crown_bronze" android:layout_marginBottom="2dp"/>
                                <com.google.android.material.imageview.ShapeableImageView
                                    android:id="@+id/imageTop3" android:layout_width="32dp" android:layout_height="32dp"
                                    android:scaleType="centerCrop" android:src="@drawable/ic_person_placeholder"
                                    app:shapeAppearanceOverlay="@style/CircleImageStyle"/>
                                <TextView android:id="@+id/tvTop3Name" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:textSize="11sp"
                                    android:textColor="@color/text_primary" android:layout_marginTop="3dp"
                                    android:maxLines="1" android:ellipsize="end"/>
                                <TextView android:id="@+id/tvTop3Goals" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:textSize="11sp"
                                    android:textColor="@color/text_hint"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 도움 TOP3 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/bg_divider"
                    app:cardBackgroundColor="@color/bg_surface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="도움 TOP3" android:textSize="13sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" android:layout_marginBottom="8dp"/>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="bottom">

                            <!-- 2위 -->
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                                android:layout_marginTop="12dp">
                                <ImageView android:layout_width="18dp" android:layout_height="12dp"
                                    android:src="@drawable/crown_silver" android:layout_marginBottom="2dp"/>
                                <com.google.android.material.imageview.ShapeableImageView
                                    android:id="@+id/imageAssistTop2" android:layout_width="36dp" android:layout_height="36dp"
                                    android:scaleType="centerCrop" android:src="@drawable/ic_person_placeholder"
                                    app:shapeAppearanceOverlay="@style/CircleImageStyle"/>
                                <TextView android:id="@+id/tvAssistTop2Name" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:textSize="11sp"
                                    android:textColor="@color/text_primary" android:layout_marginTop="3dp"
                                    android:maxLines="1" android:ellipsize="end"/>
                                <TextView android:id="@+id/tvAssistTop2Count" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:textSize="11sp"
                                    android:textColor="@color/text_hint"/>
                            </LinearLayout>

                            <!-- 1위 -->
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                                <ImageView android:layout_width="22dp" android:layout_height="14dp"
                                    android:src="@drawable/crown_gold" android:layout_marginBottom="2dp"/>
                                <com.google.android.material.imageview.ShapeableImageView
                                    android:id="@+id/imageAssistTop1" android:layout_width="44dp" android:layout_height="44dp"
                                    android:scaleType="centerCrop" android:src="@drawable/ic_person_placeholder"
                                    app:shapeAppearanceOverlay="@style/CircleImageStyle"/>
                                <TextView android:id="@+id/tvAssistTop1Name" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:textSize="12sp"
                                    android:textStyle="bold" android:textColor="@color/text_primary"
                                    android:layout_marginTop="3dp" android:maxLines="1" android:ellipsize="end"/>
                                <TextView android:id="@+id/tvAssistTop1Count" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:textSize="12sp"
                                    android:textColor="@color/text_secondary"/>
                            </LinearLayout>

                            <!-- 3위 -->
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                                android:layout_marginTop="16dp">
                                <ImageView android:layout_width="16dp" android:layout_height="10dp"
                                    android:src="@drawable/crown_bronze" android:layout_marginBottom="2dp"/>
                                <com.google.android.material.imageview.ShapeableImageView
                                    android:id="@+id/imageAssistTop3" android:layout_width="32dp" android:layout_height="32dp"
                                    android:scaleType="centerCrop" android:src="@drawable/ic_person_placeholder"
                                    app:shapeAppearanceOverlay="@style/CircleImageStyle"/>
                                <TextView android:id="@+id/tvAssistTop3Name" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:textSize="11sp"
                                    android:textColor="@color/text_primary" android:layout_marginTop="3dp"
                                    android:maxLines="1" android:ellipsize="end"/>
                                <TextView android:id="@+id/tvAssistTop3Count" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:textSize="11sp"
                                    android:textColor="@color/text_hint"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ── 개인 기록 테이블 헤더 ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/bg_divider"
                app:cardBackgroundColor="@color/bg_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 테이블 헤더 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@color/bg_secondary"
                        android:paddingHorizontal="12dp">

                        <TextView android:layout_width="28dp" android:layout_height="wrap_content"
                            android:text="순위" android:textSize="12sp" android:textColor="@color/text_hint"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="이름"
                            android:textSize="12sp" android:textColor="@color/text_hint" android:layout_marginStart="8dp"/>

                        <!-- 경기 헤더 (정렬 가능) -->
                        <LinearLayout android:id="@+id/hGames"
                            android:layout_width="50dp" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center"
                            android:clickable="true" android:focusable="true">
                            <TextView android:id="@+id/tvHdrGames"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="경기" android:textSize="12sp" android:textColor="@color/text_hint"/>
                            <ImageView android:id="@+id/icHdrGames"
                                android:layout_width="10dp" android:layout_height="10dp"
                                android:layout_marginStart="1dp"
                                android:src="@drawable/ic_arrow_down"
                                android:alpha="0"
                                android:importantForAccessibility="no"/>
                        </LinearLayout>

                        <!-- 득점 헤더 (정렬 가능, 기본 활성) -->
                        <LinearLayout android:id="@+id/hGoals"
                            android:layout_width="50dp" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center"
                            android:clickable="true" android:focusable="true">
                            <TextView android:id="@+id/tvHdrGoals"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="득점" android:textSize="12sp" android:textColor="@color/primary" android:textStyle="bold"/>
                            <ImageView android:id="@+id/icHdrGoals"
                                android:layout_width="10dp" android:layout_height="10dp"
                                android:layout_marginStart="1dp"
                                android:src="@drawable/ic_arrow_down"
                                android:importantForAccessibility="no"/>
                        </LinearLayout>

                        <!-- 도움 헤더 (정렬 가능) -->
                        <LinearLayout android:id="@+id/hAssists"
                            android:layout_width="50dp" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center"
                            android:clickable="true" android:focusable="true">
                            <TextView android:id="@+id/tvHdrAssists"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="도움" android:textSize="12sp" android:textColor="@color/text_hint"/>
                            <ImageView android:id="@+id/icHdrAssists"
                                android:layout_width="10dp" android:layout_height="10dp"
                                android:layout_marginStart="1dp"
                                android:src="@drawable/ic_arrow_down"
                                android:alpha="0"
                                android:importantForAccessibility="no"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 개인 기록 RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvPersonal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</com.jjw.soccerclub.common.StateLayout>