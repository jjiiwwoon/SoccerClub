<?xml version="1.0" encoding="utf-8"?>
<com.jjw.soccerclub.common.StateLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/stateLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:loadingLayout="@layout/view_state_loading"
    app:emptyLayout="@layout/view_state_empty"
    android:background="#E4EBF5">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- ═══ 팀 헤더 카드 ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="0dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- 팀 로고 + 이름 + 실력 -->
                    <LinearLayout
                        android:id="@+id/teamInfoBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_card_light"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/imgTeamLogo"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_shield_gray"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">

                            <TextView
                                android:id="@+id/tvTeamName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="#111827"/>

                            <TextView
                                android:id="@+id/tvSkillRange"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textColor="#6B7280"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_arrow_down"
                            android:rotation="-90"
                            android:tint="#9CA3AF"/>
                    </LinearLayout>

                    <!-- 모집 타입 + 실력 칩 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvRecruitType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#1565C0"
                            android:background="@drawable/bg_badge_recruit"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"/>

                        <TextView
                            android:id="@+id/tvRecruitSkill"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="#1565C0"
                            android:background="@drawable/bg_chip_outline_blue"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:layout_marginStart="6dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ 활동 정보 카드 ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="1dp"
                app:strokeColor="#E0E7F1"
                app:strokeWidth="0.5dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- 날짜 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/ic_calendar" android:tint="#42A5F5"
                            android:layout_marginEnd="10dp"/>
                        <TextView android:layout_width="60dp" android:layout_height="wrap_content"
                            android:text="날짜" android:textSize="13sp" android:textColor="#6B7280"/>
                        <TextView android:id="@+id/tvDate"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:textSize="14sp"
                            android:textStyle="bold" android:textColor="#111827"/>
                    </LinearLayout>

                    <!-- 시간 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/ic_clock" android:tint="#42A5F5"
                            android:layout_marginEnd="10dp"/>
                        <TextView
                            android:id="@+id/tvTimeLabel"
                            android:layout_width="60dp" android:layout_height="wrap_content"
                            android:text="활동 시간" android:textSize="13sp" android:textColor="#6B7280"/>
                        <TextView android:id="@+id/tvTime"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:textSize="14sp" android:textColor="#111827"/>
                    </LinearLayout>

                    <!-- 장소 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/ic_location_pin" android:tint="#42A5F5"
                            android:layout_marginEnd="10dp"/>
                        <TextView
                            android:id="@+id/tvStadiumLabel"
                            android:layout_width="60dp" android:layout_height="wrap_content"
                            android:text="장소" android:textSize="13sp" android:textColor="#6B7280"/>
                        <TextView android:id="@+id/tvStadium"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:textSize="14sp" android:textColor="#111827"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ 모집 포지션 카드 ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="1dp"
                app:strokeColor="#E0E7F1"
                app:strokeWidth="0.5dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/ic_baseline_group_24" android:tint="#42A5F5"
                            android:layout_marginEnd="6dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="모집 포지션" android:textStyle="bold"
                            android:textSize="15sp" android:textColor="#111827"/>
                    </LinearLayout>

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupPositions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:chipSpacingHorizontal="6dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ 모집 소개 카드 ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="1dp"
                app:strokeColor="#E0E7F1"
                app:strokeWidth="0.5dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="모집 소개"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="#111827"
                        android:layout_marginBottom="8dp"/>

                    <TextView android:id="@+id/tvIntro"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#4B5563"
                        android:lineSpacingMultiplier="1.5"
                        android:minHeight="48dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ 신청 버튼 ═══ -->
            <Button android:id="@+id/btnApply"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginHorizontal="14dp"
                android:layout_marginTop="16dp"
                android:text="신청하기"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/primary"
                app:cornerRadius="12dp"/>

            <!-- 작성자 전용 (숨김, ID 호환) -->
            <LinearLayout
                android:id="@+id/layoutWriterActions"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:orientation="horizontal"
                android:visibility="gone">
                <Button android:id="@+id/btnCloseRecruit"
                    android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
                <Button android:id="@+id/btnDeleteRecruit"
                    android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</com.jjw.soccerclub.common.StateLayout>