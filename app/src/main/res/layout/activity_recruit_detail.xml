<?xml version="1.0" encoding="utf-8"?>
<com.example.soccerclub.common.StateLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/stateLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:loadingLayout="@layout/view_state_loading"
    app:emptyLayout="@layout/view_state_empty"
    android:background="@color/bg_page">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/page_padding_horizontal">

            <!-- 팀 정보 카드 -->
            <LinearLayout
                android:id="@+id/teamInfoBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card"
                android:padding="@dimen/card_padding"
                android:layout_marginTop="@dimen/spacing_lg"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/imgTeamLogo"
                    android:layout_width="@dimen/avatar_md"
                    android:layout_height="@dimen/avatar_md"
                    android:scaleType="centerCrop"
                    android:contentDescription="팀 로고"
                    android:src="@drawable/ic_shield_gray"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="@dimen/spacing_md">

                    <TextView
                        android:id="@+id/tvTeamName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tvSkillRange"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="@dimen/spacing_xs"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/icon_sm"
                    android:layout_height="@dimen/icon_sm"
                    android:src="@drawable/ic_arrow_down"
                    app:tint="@color/text_hint"/>
            </LinearLayout>

            <!-- 모집 타입 + 실력 칩 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/spacing_md"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvRecruitType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/primary"
                    android:background="@drawable/bg_filter_chip_selector"
                    android:paddingHorizontal="@dimen/chip_padding_horizontal"
                    android:paddingVertical="@dimen/chip_padding_vertical"/>

                <TextView
                    android:id="@+id/tvRecruitSkill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_filter_chip_selector"
                    android:paddingHorizontal="@dimen/chip_padding_horizontal"
                    android:paddingVertical="@dimen/chip_padding_vertical"
                    android:layout_marginStart="@dimen/spacing_xs"/>
            </LinearLayout>

            <!-- 구분선 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/divider_height"
                android:background="@color/bg_divider"
                android:layout_marginVertical="@dimen/spacing_md"/>

            <!-- 날짜 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_sm">

                <TextView
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="날짜"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/text_secondary"/>

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_md"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <!-- 시간 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_sm">

                <TextView
                    android:id="@+id/tvTimeLabel"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="시간"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/text_secondary"/>

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_md"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <!-- 장소 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_md">

                <TextView
                    android:id="@+id/tvStadiumLabel"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="장소"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/text_secondary"/>

                <TextView
                    android:id="@+id/tvStadium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="@dimen/text_md"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <!-- 구분선 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/divider_height"
                android:background="@color/bg_divider"
                android:layout_marginBottom="@dimen/spacing_md"/>

            <!-- 포지션 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="모집 포지션"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_md"
                android:layout_marginBottom="@dimen/spacing_xs"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupPositions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:chipSpacingHorizontal="@dimen/spacing_xs"/>

            <!-- 구분선 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/divider_height"
                android:background="@color/bg_divider"
                android:layout_marginBottom="@dimen/spacing_md"/>

            <!-- 소개 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="모집 소개"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_md"
                android:layout_marginBottom="@dimen/spacing_xs"/>

            <TextView
                android:id="@+id/tvIntro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_md"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.4"/>

            <!-- 신청 버튼 -->
            <Button
                android:id="@+id/btnApply"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="신청하기"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:backgroundTint="@color/primary"
                app:cornerRadius="@dimen/btn_radius"/>

            <!-- ✅ 작성자 전용: 마감 / 삭제 버튼 (기본 GONE, 작성자에게만 표시) -->
            <LinearLayout
                android:id="@+id/layoutWriterActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                android:layout_marginTop="@dimen/spacing_sm"
                android:layout_marginBottom="@dimen/spacing_xl">

                <Button
                    android:id="@+id/btnCloseRecruit"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/btn_height"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:text="모집 마감"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/text_secondary"
                    android:textAllCaps="false"
                    app:cornerRadius="@dimen/btn_radius"/>

                <Button
                    android:id="@+id/btnDeleteRecruit"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/btn_height"
                    android:layout_weight="1"
                    android:text="글 삭제"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/loss"
                    android:textAllCaps="false"
                    app:cornerRadius="@dimen/btn_radius"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</com.example.soccerclub.common.StateLayout>