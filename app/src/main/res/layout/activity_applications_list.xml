<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_page">

    <!-- 내 글 / 신청한 글 탭 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/bg_surface">

        <TextView
            android:id="@+id/btnSubjectMine"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="내가 올린 글"
            android:textSize="@dimen/text_md"
            android:textColor="@color/primary"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btnSubjectApplied"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="신청한 글"
            android:textSize="@dimen/text_md"
            android:textColor="@color/text_hint"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- 타입 필터 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bg_surface"
        android:paddingHorizontal="@dimen/spacing_md">

        <TextView
            android:id="@+id/chipTypeAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="전체"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/primary"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingVertical="@dimen/spacing_xs"
            android:background="@drawable/bg_chip"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/chipTypeMatch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="시합"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/text_hint"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingVertical="@dimen/spacing_xs"
            android:background="@drawable/bg_chip"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/chipTypeRecruit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="모집"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/text_hint"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingVertical="@dimen/spacing_xs"
            android:background="@drawable/bg_chip"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="@dimen/spacing_sm"
        android:clipToPadding="false"/>

</LinearLayout>