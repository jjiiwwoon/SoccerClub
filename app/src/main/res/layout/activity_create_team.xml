<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8EFF8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <!-- ── 섹션 1: 팀 기본 정보 ── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                android:src="@drawable/ic_shield_gray" android:layout_marginEnd="5dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="팀 기본 정보" android:textSize="14sp" android:textStyle="bold"
                android:textColor="#111827"/>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:strokeWidth="1dp"
            app:strokeColor="#B8C5D6"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <ImageView
                        android:id="@+id/imageTeamLogo"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_rounded_rect_12"
                        android:clipToOutline="true"
                        android:src="@drawable/ic_shield_gray"/>

                    <Button
                        android:id="@+id/btnSelectLogo"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="14dp"
                        android:text="로고 선택"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="@color/primary"
                        android:backgroundTint="@android:color/transparent"
                        app:strokeColor="@color/primary"
                        app:strokeWidth="1dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="팀 이름"
                    android:layout_marginBottom="12dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="10dp" app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp" app:boxCornerRadiusBottomEnd="10dp"
                    app:boxBackgroundColor="#F3F6FA">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editTeamName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:inputType="text"/>
                </com.google.android.material.textfield.TextInputLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="활동 지역" android:textSize="12sp"
                    android:textColor="#6B7280" android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <Spinner android:id="@+id/spinnerCity"
                        android:layout_width="0dp" android:layout_height="48dp"
                        android:layout_weight="1" android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_input"/>
                    <Spinner android:id="@+id/spinnerDistrict"
                        android:layout_width="0dp" android:layout_height="48dp"
                        android:layout_weight="1" android:background="@drawable/bg_input"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── 섹션 2: 팀 조건 ── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                android:src="@drawable/ic_clock" android:tint="#42A5F5"
                android:layout_marginEnd="5dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="팀 조건" android:textSize="14sp" android:textStyle="bold"
                android:textColor="#111827"/>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:strokeWidth="1dp"
            app:strokeColor="#B8C5D6"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="나이대" android:textSize="12sp"
                    android:textColor="#6B7280" android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <Spinner android:id="@+id/spinnerAgeStart"
                        android:layout_width="0dp" android:layout_height="48dp"
                        android:layout_weight="1" android:layout_marginEnd="4dp"
                        android:background="@drawable/bg_input"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text=" ~ " android:textColor="#9CA3AF" android:textSize="14sp"
                        android:layout_marginEnd="4dp"/>
                    <Spinner android:id="@+id/spinnerAgeEnd"
                        android:layout_width="0dp" android:layout_height="48dp"
                        android:layout_weight="1" android:background="@drawable/bg_input"/>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="활동 요일/시간" android:textSize="12sp"
                    android:textColor="#6B7280" android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <Spinner android:id="@+id/spinnerActivityDay"
                        android:layout_width="0dp" android:layout_height="48dp"
                        android:layout_weight="1" android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_input"/>
                    <Spinner android:id="@+id/spinnerTimeStart"
                        android:layout_width="0dp" android:layout_height="48dp"
                        android:layout_weight="1" android:layout_marginEnd="4dp"
                        android:background="@drawable/bg_input"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text=" ~ " android:textColor="#9CA3AF" android:textSize="14sp"
                        android:layout_marginEnd="4dp"/>
                    <Spinner android:id="@+id/spinnerTimeEnd"
                        android:layout_width="0dp" android:layout_height="48dp"
                        android:layout_weight="1" android:background="@drawable/bg_input"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── 섹션 4: 주 활동 구장 ── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                android:src="@drawable/ic_location_pin" android:tint="#42A5F5"
                android:layout_marginEnd="5dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="주 활동 구장" android:textSize="14sp" android:textStyle="bold"
                android:textColor="#111827"/>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:strokeWidth="1dp"
            app:strokeColor="#B8C5D6"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="구장명"
                    android:layout_marginBottom="10dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="10dp" app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp" app:boxCornerRadiusBottomEnd="10dp"
                    app:boxBackgroundColor="#F3F6FA">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editStadiumName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:inputType="text"/>
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView android:id="@+id/editStadium"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="주소가 선택되지 않았습니다."
                        android:textSize="13sp" android:textColor="#9CA3AF"
                        android:layout_marginEnd="8dp"/>
                    <Button android:id="@+id/btnSearchStadium"
                        android:layout_width="wrap_content" android:layout_height="36dp"
                        android:text="주소 검색" android:textAllCaps="false"
                        android:textSize="12sp" android:textColor="@color/white"
                        android:backgroundTint="@color/primary"
                        android:stateListAnimator="@null"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── 섹션 5: 팀 소개 ── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                android:src="@drawable/ic_baseline_bar_chart_24" android:tint="#42A5F5"
                android:layout_marginEnd="5dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="팀 소개" android:textSize="14sp" android:textStyle="bold"
                android:textColor="#111827"/>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:strokeWidth="1dp"
            app:strokeColor="#B8C5D6"
            app:cardBackgroundColor="#FFFFFF">

            <EditText
                android:id="@+id/editTeamIntro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:gravity="top"
                android:hint="팀 소개를 입력해주세요"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:padding="16dp"
                android:textColor="@color/text_primary"
                android:textColorHint="#9CA3AF"
                android:textSize="14sp"/>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveTeam"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="24dp"
            android:text="팀 생성하기"
            android:textColor="@color/white"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/primary"
            app:cornerRadius="12dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>