<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- 내 투표 버튼 행 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVoteAttend"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="✓ 참석"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:backgroundTint="@color/primary"
            app:cornerRadius="10dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVoteAbsent"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="✗ 불참"
            android:textAllCaps="false"
            android:textColor="@color/loss"
            android:backgroundTint="@color/bg_surface"
            app:strokeColor="@color/loss"
            app:strokeWidth="1dp"
            app:cornerRadius="10dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>
    </LinearLayout>

    <!-- 내 현재 투표 상태 -->
    <TextView
        android:id="@+id/tvMyVoteStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="아직 투표하지 않았어요."
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginBottom="12dp"/>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/bg_divider"
        android:layout_marginBottom="12dp"/>

    <!-- 참석자 -->
    <TextView
        android:id="@+id/tvAttendHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="참석 (0)"
        android:textStyle="bold"
        android:textSize="14sp"
        android:textColor="@color/primary"
        android:layout_marginBottom="6dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAttend"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false"/>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/bg_divider"
        android:layout_marginVertical="10dp"/>

    <!-- 불참자 -->
    <TextView
        android:id="@+id/tvAbsentHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="불참 (0)"
        android:textStyle="bold"
        android:textSize="14sp"
        android:textColor="@color/loss"
        android:layout_marginBottom="6dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAbsent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false"/>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/bg_divider"
        android:layout_marginVertical="10dp"/>

    <!-- 미투표자 -->
    <TextView
        android:id="@+id/tvNotVotedHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="미투표 (0)"
        android:textStyle="bold"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="6dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvNotVoted"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false"/>

</LinearLayout>