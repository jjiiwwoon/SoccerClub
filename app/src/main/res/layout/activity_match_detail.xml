<?xml version="1.0" encoding="utf-8"?>
<com.jjw.soccerclub.common.StateLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/state"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:loadingLayout="@layout/view_state_loading"
    app:emptyLayout="@layout/view_state_empty"
    android:background="@color/bg_page">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/page_padding_horizontal">

            <!-- 팀 정보 -->
            <LinearLayout
                android:id="@+id/teamInfoBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card"
                android:padding="@dimen/card_padding"
                android:layout_marginTop="@dimen/spacing_lg"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/imgTeamLogo"
                    android:layout_width="@dimen/avatar_md"
                    android:layout_height="@dimen/avatar_md"
                    android:scaleType="centerCrop"
                    android:contentDescription="팀 로고"
                    android:src="@drawable/ic_shield_gray"/>

                <TextView
                    android:id="@+id/txtTeamName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:textSize="@dimen/text_xl"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <!-- 칩 (나이대 / 지역 / 실력) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/spacing_sm">

                <TextView android:id="@+id/chipAge"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/chip_padding_horizontal"
                    android:paddingVertical="@dimen/chip_padding_vertical"
                    android:background="@drawable/bg_chip"
                    android:textSize="@dimen/text_sm" android:textColor="@color/chip_text"
                    android:layout_marginEnd="@dimen/spacing_xs"/>

                <TextView android:id="@+id/chipRegion"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/chip_padding_horizontal"
                    android:paddingVertical="@dimen/chip_padding_vertical"
                    android:background="@drawable/bg_chip"
                    android:textSize="@dimen/text_sm" android:textColor="@color/chip_text"
                    android:layout_marginEnd="@dimen/spacing_xs"/>

                <TextView android:id="@+id/chipSkill"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/chip_padding_horizontal"
                    android:paddingVertical="@dimen/chip_padding_vertical"
                    android:background="@drawable/bg_chip"
                    android:textSize="@dimen/text_sm" android:textColor="@color/chip_text"/>
            </LinearLayout>

            <!-- 구분선 -->
            <View android:layout_width="match_parent" android:layout_height="@dimen/divider_height"
                android:background="@color/bg_divider"
                android:layout_marginVertical="@dimen/spacing_md"/>

            <!-- 날짜/시간 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="@dimen/spacing_sm">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="일정" android:textColor="@color/text_secondary" android:textSize="@dimen/text_md"/>
                <TextView android:id="@+id/txtDateTime" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:textColor="@color/text_primary" android:textSize="@dimen/text_md"/>
            </LinearLayout>

            <!-- 장소 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="@dimen/spacing_sm">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="구장" android:textColor="@color/text_secondary" android:textSize="@dimen/text_md"/>
                <TextView android:id="@+id/txtStadium" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:textColor="@color/text_primary" android:textSize="@dimen/text_md"/>
            </LinearLayout>

            <!-- 주소 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="@dimen/spacing_sm">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="주소" android:textColor="@color/text_secondary" android:textSize="@dimen/text_md"/>
                <TextView android:id="@+id/txtAddress" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:textColor="@color/primary" android:textSize="@dimen/text_md"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <!-- 구분선 -->
            <View android:layout_width="match_parent" android:layout_height="@dimen/divider_height"
                android:background="@color/bg_divider"
                android:layout_marginVertical="@dimen/spacing_md"/>

            <!-- 최근 전적 -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="최근 전적" android:textStyle="bold"
                android:textSize="@dimen/text_lg" android:textColor="@color/text_primary"
                android:layout_marginBottom="@dimen/spacing_sm"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center"
                android:layout_marginBottom="@dimen/spacing_sm">

                <TextView android:id="@+id/tile1" android:layout_width="40dp" android:layout_height="40dp"
                    android:gravity="center" android:text="-" android:textSize="@dimen/text_md"
                    android:background="@drawable/bg_result_neutral" android:layout_marginEnd="4dp"/>
                <TextView android:id="@+id/tile2" android:layout_width="40dp" android:layout_height="40dp"
                    android:gravity="center" android:text="-" android:textSize="@dimen/text_md"
                    android:background="@drawable/bg_result_neutral" android:layout_marginEnd="4dp"/>
                <TextView android:id="@+id/tile3" android:layout_width="40dp" android:layout_height="40dp"
                    android:gravity="center" android:text="-" android:textSize="@dimen/text_md"
                    android:background="@drawable/bg_result_neutral" android:layout_marginEnd="4dp"/>
                <TextView android:id="@+id/tile4" android:layout_width="40dp" android:layout_height="40dp"
                    android:gravity="center" android:text="-" android:textSize="@dimen/text_md"
                    android:background="@drawable/bg_result_neutral" android:layout_marginEnd="4dp"/>
                <TextView android:id="@+id/tile5" android:layout_width="40dp" android:layout_height="40dp"
                    android:gravity="center" android:text="-" android:textSize="@dimen/text_md"
                    android:background="@drawable/bg_result_neutral"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center"
                android:layout_marginBottom="@dimen/spacing_sm">
                <TextView android:id="@+id/tvRecentWin"  android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/win"  android:textSize="@dimen/text_sm" android:text="승 0"/>
                <TextView android:id="@+id/tvRecentDraw" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/draw" android:textSize="@dimen/text_sm" android:text="  ·  무 0"/>
                <TextView android:id="@+id/tvRecentLoss" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/loss" android:textSize="@dimen/text_sm" android:text="  ·  패 0"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center"
                android:layout_marginBottom="@dimen/spacing_md">
                <TextView android:id="@+id/tvRecentGF" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/goal_for" android:textSize="@dimen/text_sm" android:text="득점 0"/>
                <TextView android:id="@+id/tvRecentGA" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/goal_against" android:textSize="@dimen/text_sm" android:text=" · 실점 0"/>
            </LinearLayout>

            <!-- 설명 -->
            <View android:layout_width="match_parent" android:layout_height="@dimen/divider_height"
                android:background="@color/bg_divider"
                android:layout_marginVertical="@dimen/spacing_md"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="시합 소개" android:textStyle="bold"
                android:textSize="@dimen/text_lg" android:textColor="@color/text_primary"
                android:layout_marginBottom="@dimen/spacing_xs"/>

            <TextView android:id="@+id/txtDescription"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="@dimen/text_md" android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.4"/>

            <!-- 신청 버튼 -->
            <Button android:id="@+id/btnApply"
                android:layout_width="match_parent" android:layout_height="@dimen/btn_height"
                android:layout_marginTop="@dimen/spacing_xl"
                android:layout_marginBottom="@dimen/spacing_xl"
                android:text="신청하기" android:textAllCaps="false"
                android:textColor="@color/white"
                android:backgroundTint="@color/primary"
                app:cornerRadius="@dimen/btn_radius"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</com.jjw.soccerclub.common.StateLayout>