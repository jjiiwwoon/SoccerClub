<?xml version="1.0" encoding="utf-8"?>
<!--
    회원/용병 모집 카드 — Capstone 스타일
    ✅ 기존 뷰 ID 전부 유지
    ✅ 로고 좌측 + 정보 우측 + 뱃지 우상단
    ✅ 날짜+시간 한 줄 / 장소 한 줄 / 실력 한 줄
    ✅ 하단: 팀명 + 포지션칩(컬러) + 타임스탬프
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="6dp"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeColor="#B8C5D6"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── 메인 콘텐츠 ── -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp">

            <!-- 좌측: 로고 -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imageTeamLogo"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_shield_gray"
                app:shapeAppearanceOverlay="@style/RoundedImageStyle"/>

            <!-- 우상단: 모집유형 뱃지 -->
            <TextView
                android:id="@+id/textRecruitType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_recruit"
                android:textColor="@color/badge_recruit_text"
                android:visibility="gone"/>

            <!-- 우측: 정보 컬럼 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/imageTeamLogo"
                android:layout_toStartOf="@id/textRecruitType"
                android:layout_centerVertical="true"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp">

                <!-- 날짜(요일) + 시간 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_calendar"
                        android:tint="#42A5F5"
                        android:layout_marginEnd="5dp"/>

                    <TextView
                        android:id="@+id/textDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#111827"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  |  "
                        android:textSize="12sp"
                        android:textColor="#D1D5DB"/>

                    <TextView
                        android:id="@+id/textTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#4B5563"/>
                </LinearLayout>

                <!-- 장소 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_location_pin"
                        android:tint="#42A5F5"
                        android:layout_marginEnd="5dp"/>

                    <TextView
                        android:id="@+id/textStadium"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="12sp"
                        android:textColor="#6B7280"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                </LinearLayout>

                <!-- 실력 -->
                <TextView
                    android:id="@+id/textSkill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:textSize="11sp"
                    android:textColor="#1565C0"
                    android:background="@drawable/bg_chip_outline_blue"
                    android:visibility="gone"/>

            </LinearLayout>
        </RelativeLayout>

        <!-- ── 구분선 ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#E5E7EB"
            android:layout_marginHorizontal="14dp"/>

        <!-- ── 하단: 팀명 + 포지션 칩 + 타임스탬프 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp">

            <!-- 팀명 -->
            <TextView
                android:id="@+id/textTeamName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginEnd="8dp"/>

            <!-- 포지션 칩 컨테이너 -->
            <LinearLayout
                android:id="@+id/positionChipsContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"/>

            <!-- 등록 시간 -->
            <TextView
                android:id="@+id/textTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#9CA3AF"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>