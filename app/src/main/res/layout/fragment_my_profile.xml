<?xml version="1.0" encoding="utf-8"?>
<!--
    ✅ 모든 기존 ID 유지:
    state / profileImageView / textNickname / textAge / textPositionBox /
    textSkill / textFoot / textHeight / textWeight / textPlayerType /
    textIntroContent / toggleIntroArrow / textTeam / teamLogo /
    statsTeamGames / statsTeamGoals / statsTeamAssists /
    statsMercGames / statsMercGoals / statsMercAssists /
    btnEditProfile / btnLogout
-->
<com.jjw.soccerclub.common.StateLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/state"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:loadingLayout="@layout/view_state_loading"
    app:emptyLayout="@layout/view_state_empty"
    android:background="@color/bg_page">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══════════════════════════════════════════════════════════════════
                 히어로 영역: 그라디언트 배경 + 프로필 사진 + 이름 + 팀
            ══════════════════════════════════════════════════════════════════ -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="220dp">

                <!-- 그라디언트 배경 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_profile_hero_gradient"/>

                <!-- 편집 버튼 (우상단) -->
                <ImageButton
                    android:id="@+id/btnEditProfile"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="14dp"
                    android:src="@drawable/ic_edit"
                    android:background="@drawable/bg_white_alpha_20"
                    android:padding="8dp"
                    android:contentDescription="편집"/>

                <!-- 중앙: 프로필 사진 + 닉네임 + 팀 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="10dp">

                    <!-- 프로필 사진 (원형 + 흰 테두리) -->
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/profileImageView"
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_person_placeholder"
                        app:shapeAppearanceOverlay="@style/CircleImageStyle"
                        app:strokeWidth="3dp"
                        app:strokeColor="#FFFFFF"/>

                    <!-- 닉네임 -->
                    <TextView
                        android:id="@+id/textNickname"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:shadowColor="#40000000"
                        android:shadowDx="0"
                        android:shadowDy="1"
                        android:shadowRadius="4"/>

                    <!-- 팀 칩 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_white_alpha_20"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="5dp"
                        android:layout_marginTop="8dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/teamLogo"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_shield_gray"
                            app:shapeAppearanceOverlay="@style/CircleImageStyle"/>

                        <TextView
                            android:id="@+id/textTeam"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:textSize="13sp"
                            android:textColor="#FFFFFF"/>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- ══════════════════════════════════════════════════════════════════
                 바디: 흰 배경 라운드로 히어로 위로 올라옴
            ══════════════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/bg_page"
                android:layout_marginTop="-20dp"
                android:paddingTop="4dp"
                android:paddingHorizontal="16dp">

                <!-- ── 포지션 + 실력 강조 배너 ── -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/bg_divider"
                    app:cardBackgroundColor="@color/bg_surface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <!-- 포지션 (색깔 강조) -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="포지션"
                                android:textSize="11sp"
                                android:textColor="@color/text_hint"/>

                            <TextView
                                android:id="@+id/textPositionBox"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary"/>
                        </LinearLayout>

                        <!-- 구분선 -->
                        <View
                            android:layout_width="0.5dp"
                            android:layout_height="match_parent"
                            android:background="@color/bg_divider"
                            android:layout_marginHorizontal="8dp"/>

                        <!-- 실력 (숫자 크게) -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="실력"
                                android:textSize="11sp"
                                android:textColor="@color/text_hint"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginTop="4dp">

                                <TextView
                                    android:id="@+id/textSkill"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="28sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_primary"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="/10"
                                    android:textSize="14sp"
                                    android:textColor="@color/text_hint"
                                    android:layout_marginStart="2dp"
                                    android:layout_marginTop="8dp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- 구분선 -->
                        <View
                            android:layout_width="0.5dp"
                            android:layout_height="match_parent"
                            android:background="@color/bg_divider"
                            android:layout_marginHorizontal="8dp"/>

                        <!-- 나이 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="나이"
                                android:textSize="11sp"
                                android:textColor="@color/text_hint"/>

                            <TextView
                                android:id="@+id/textAge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── 스탯 그리드 (주발 / 신장 / 몸무게) ── -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/bg_divider"
                    app:cardBackgroundColor="@color/bg_surface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <!-- 주발 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@color/bg_secondary"
                            android:padding="12dp"
                            android:layout_marginEnd="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="주발" android:textSize="11sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/textFoot" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:textSize="16sp"
                                android:textStyle="bold" android:textColor="@color/text_primary"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <!-- 신장 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@color/bg_secondary"
                            android:padding="12dp"
                            android:layout_marginEnd="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="신장" android:textSize="11sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/textHeight" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:textSize="16sp"
                                android:textStyle="bold" android:textColor="@color/text_primary"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <!-- 몸무게 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@color/bg_secondary"
                            android:padding="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="몸무게" android:textSize="11sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/textWeight" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:textSize="16sp"
                                android:textStyle="bold" android:textColor="@color/text_primary"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── 선수 유형 + 자기소개 ── -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/bg_divider"
                    app:cardBackgroundColor="@color/bg_surface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- 선수 유형 행 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingBottom="12dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="선수 유형"
                                android:textSize="13sp"
                                android:textColor="@color/text_secondary"/>
                            <TextView
                                android:id="@+id/textPlayerType"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary"
                                android:background="@drawable/bg_badge_recruit"/>
                        </LinearLayout>

                        <!-- 구분선 -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="0.5dp"
                            android:background="@color/bg_divider"
                            android:layout_marginBottom="12dp"/>

                        <!-- 자기소개 헤더 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="자기소개"
                                android:textSize="13sp"
                                android:textColor="@color/text_secondary"/>
                            <ImageView
                                android:id="@+id/toggleIntroArrow"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_arrow_down"
                                android:clickable="true"
                                android:focusable="true"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/textIntroContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:lineSpacingExtra="2dp"
                            android:maxLines="2"
                            android:ellipsize="end"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── 기록 카드 ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <!-- 팀 기록 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/bg_divider"
                        app:cardBackgroundColor="@color/bg_surface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <!-- 헤더 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="12dp">
                                <View
                                    android:layout_width="3dp"
                                    android:layout_height="14dp"
                                    android:background="@color/primary"
                                    android:layout_marginEnd="6dp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="팀 기록"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_primary"/>
                            </LinearLayout>

                            <!-- 경기 -->
                            <LinearLayout android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="8dp">
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:text="경기"
                                    android:textSize="12sp" android:textColor="@color/text_hint"/>
                                <TextView android:id="@+id/statsTeamGames"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="0" android:textSize="15sp"
                                    android:textStyle="bold" android:textColor="@color/text_primary"/>
                            </LinearLayout>
                            <!-- 득점 -->
                            <LinearLayout android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="8dp">
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:text="득점"
                                    android:textSize="12sp" android:textColor="@color/text_hint"/>
                                <TextView android:id="@+id/statsTeamGoals"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="0" android:textSize="15sp"
                                    android:textStyle="bold" android:textColor="@color/text_primary"/>
                            </LinearLayout>
                            <!-- 도움 -->
                            <LinearLayout android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:text="도움"
                                    android:textSize="12sp" android:textColor="@color/text_hint"/>
                                <TextView android:id="@+id/statsTeamAssists"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="0" android:textSize="15sp"
                                    android:textStyle="bold" android:textColor="@color/text_primary"/>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 용병 기록 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/bg_divider"
                        app:cardBackgroundColor="@color/bg_surface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <!-- 헤더 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="12dp">
                                <View
                                    android:layout_width="3dp"
                                    android:layout_height="14dp"
                                    android:background="#E65100"
                                    android:layout_marginEnd="6dp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="용병 기록"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_primary"/>
                            </LinearLayout>

                            <!-- 경기 -->
                            <LinearLayout android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="8dp">
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:text="경기"
                                    android:textSize="12sp" android:textColor="@color/text_hint"/>
                                <TextView android:id="@+id/statsMercGames"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="0" android:textSize="15sp"
                                    android:textStyle="bold" android:textColor="@color/text_primary"/>
                            </LinearLayout>
                            <!-- 득점 -->
                            <LinearLayout android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="8dp">
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:text="득점"
                                    android:textSize="12sp" android:textColor="@color/text_hint"/>
                                <TextView android:id="@+id/statsMercGoals"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="0" android:textSize="15sp"
                                    android:textStyle="bold" android:textColor="@color/text_primary"/>
                            </LinearLayout>
                            <!-- 도움 -->
                            <LinearLayout android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:text="도움"
                                    android:textSize="12sp" android:textColor="@color/text_hint"/>
                                <TextView android:id="@+id/statsMercAssists"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="0" android:textSize="15sp"
                                    android:textStyle="bold" android:textColor="@color/text_primary"/>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- ── 로그아웃 버튼 ── -->
                <Button
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="24dp"
                    android:text="로그아웃"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textColor="#C62828"
                    android:backgroundTint="@android:color/transparent"
                    app:strokeColor="#FFCDD2"
                    app:strokeWidth="1dp"
                    android:stateListAnimator="@null"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</com.jjw.soccerclub.common.StateLayout>