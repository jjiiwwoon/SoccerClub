<?xml version="1.0" encoding="utf-8"?>
<com.jjw.soccerclub.common.StateLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/state"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:loadingLayout="@layout/view_state_loading"
    app:emptyLayout="@layout/view_state_empty"
    android:background="@color/bg_page">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══ 히어로 헤더 (파란 배경) ══════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="24dp"
                android:paddingBottom="32dp"
                android:paddingHorizontal="20dp"
                android:background="@color/primary">

                <!-- 프로필 사진 + 닉네임 + 팀 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- 프로필 사진 (원형) -->
                    <ImageView
                        android:id="@+id/profileImageView"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_person_placeholder"
                        android:background="@drawable/bg_circle_white_alpha"
                        android:clipToOutline="true"/>

                    <!-- 닉네임 + 팀 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:id="@+id/textNickname"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"/>

                        <!-- 팀 로고 + 팀명 -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_white_alpha_20"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:layout_marginTop="6dp">

                            <ImageView
                                android:id="@+id/teamLogo"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_shield_gray"/>

                            <TextView
                                android:id="@+id/textTeam"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="13sp"
                                android:textColor="#FFFFFF"
                                android:layout_marginStart="6dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 편집 버튼 -->
                    <ImageButton
                        android:id="@+id/btnEditProfile"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_edit"
                        android:background="@drawable/bg_white_alpha_20"
                        android:padding="6dp"
                        android:contentDescription="프로필 편집"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ══ 바디 (흰 라운드 카드로 올라옴) ══════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/bg_page"
                android:layout_marginTop="-16dp"
                android:paddingTop="16dp"
                android:paddingHorizontal="16dp">

                <!-- ── 스탯 그리드 (2×3) ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/bg_surface"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="스탯"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="12dp"/>

                    <!-- 1행: 나이 / 포지션 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@color/bg_secondary"
                            android:padding="12dp"
                            android:layout_marginEnd="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="나이" android:textSize="11sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/textAge" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:textSize="16sp"
                                android:textStyle="bold" android:textColor="@color/text_primary"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@color/bg_secondary"
                            android:padding="12dp"
                            android:layout_marginStart="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="포지션" android:textSize="11sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/textPositionBox" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:textSize="16sp"
                                android:textStyle="bold" android:textColor="@color/text_primary"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 2행: 실력 / 주발 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@color/bg_secondary"
                            android:padding="12dp"
                            android:layout_marginEnd="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="실력" android:textSize="11sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/textSkill" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:textSize="16sp"
                                android:textStyle="bold" android:textColor="@color/text_primary"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@color/bg_secondary"
                            android:padding="12dp"
                            android:layout_marginStart="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="주발" android:textSize="11sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/textFoot" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:textSize="16sp"
                                android:textStyle="bold" android:textColor="@color/text_primary"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 3행: 신장 / 몸무게 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@color/bg_secondary"
                            android:padding="12dp"
                            android:layout_marginEnd="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="신장" android:textSize="11sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/textHeight" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:textSize="16sp"
                                android:textStyle="bold" android:textColor="@color/text_primary"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@color/bg_secondary"
                            android:padding="12dp"
                            android:layout_marginStart="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="몸무게" android:textSize="11sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/textWeight" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:textSize="16sp"
                                android:textStyle="bold" android:textColor="@color/text_primary"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

                <!-- ── 자기소개 ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/bg_surface"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="자기소개"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"/>
                        <ImageView
                            android:id="@+id/toggleIntroArrow"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_arrow_down"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/textIntroContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:maxLines="2"
                        android:ellipsize="end"/>
                </LinearLayout>

                <!-- ── 선수 유형 ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/bg_surface"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="선수 유형"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"/>
                    <TextView
                        android:id="@+id/textPlayerType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>

                <!-- ── 기록 카드 ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <!-- 팀 기록 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@color/bg_surface"
                        android:padding="14dp"
                        android:layout_marginEnd="6dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="팀 기록"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="10dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="경기"
                                android:textSize="12sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/statsTeamGames" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0"
                                android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="득점"
                                android:textSize="12sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/statsTeamGoals" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0"
                                android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="도움"
                                android:textSize="12sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/statsTeamAssists" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0"
                                android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 용병 기록 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@color/bg_surface"
                        android:padding="14dp"
                        android:layout_marginStart="6dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="용병 기록"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="10dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="경기"
                                android:textSize="12sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/statsMercGames" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0"
                                android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="득점"
                                android:textSize="12sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/statsMercGoals" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0"
                                android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="도움"
                                android:textSize="12sp" android:textColor="@color/text_hint"/>
                            <TextView android:id="@+id/statsMercAssists" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0"
                                android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

                <!-- 하단 여백 -->
                <View android:layout_width="match_parent" android:layout_height="24dp"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</com.jjw.soccerclub.common.StateLayout>