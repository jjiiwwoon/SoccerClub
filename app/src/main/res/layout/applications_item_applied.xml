<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="14dp">

    <CheckBox
        android:id="@+id/cbSelect"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="4dp"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        app:cardCornerRadius="14dp"
        app:cardElevation="2dp"
        app:strokeColor="#B8C5D6"
        app:strokeWidth="1dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:id="@+id/rootApplied"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <include
                android:id="@+id/includePost"
                layout="@layout/match_post_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="0dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#C5D0DE"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp"
                android:background="#F5F7FA">

                <TextView
                    android:id="@+id/textApplicationStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:paddingHorizontal="12dp"
                    android:gravity="center"
                    android:text="대기중"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_status_chip_pending"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/textAppliedTimestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>