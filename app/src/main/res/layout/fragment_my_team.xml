<?xml version="1.0" encoding="utf-8"?>
<!--
    내 팀 프래그먼트 — Capstone 스타일 리디자인
    ✅ 기존 뷰 ID 전부 유지
    ✅ nextScheduleContainer 추가 (showNoScheduleMessage 동작)
    ✅ view_next_schedule_card include 방식으로 전환
    ✅ 히어로 헤더 + 그라디언트 오버레이
    ✅ MaterialCardView 오버랩 팀 정보 카드
    ✅ 아이콘 섹션 헤더 (일정 / 기록 / 멤버)
    ✅ 기록 카드 스타일 (색상 적용)
-->
<com.jjw.soccerclub.common.StateLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/stateLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:loadingLayout="@layout/view_state_loading"
    app:emptyLayout="@layout/view_state_empty"
    android:background="#F7F9FC">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/spacing_xl">

            <!-- ═══════════════════════════════════════════════════
                 히어로 헤더 (팀 사진 + 그라디언트 오버레이)
                 ═══════════════════════════════════════════════════ -->
            <FrameLayout
                android:id="@+id/heroHeader"
                android:layout_width="match_parent"
                android:layout_height="200dp">

                <ImageView
                    android:id="@+id/teamPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/default_team_photo"
                    android:clickable="true"
                    android:focusable="true"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_header_gradient"/>
            </FrameLayout>

            <!-- ═══════════════════════════════════════════════════
                 팀 정보 카드 (히어로 위로 오버랩)
                 ═══════════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-24dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeColor="#E8EEF5"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- ── 로고 + 팀명 박스 (Capstone 스타일) ── -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/teamHeaderBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        app:cardBackgroundColor="#F3F6FA"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="12dp">

                            <ImageView
                                android:id="@+id/teamLogo"
                                android:layout_width="72dp"
                                android:layout_height="72dp"
                                android:layout_marginEnd="16dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_shield_gray"/>

                            <TextView
                                android:id="@+id/teamName"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#111827"/>

                            <ImageView
                                android:id="@+id/introToggle"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:padding="4dp"
                                android:src="@drawable/ic_arrow_down"
                                android:clickable="true"
                                android:focusable="true"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- ── 스펙 리스트 (라벨 + 값 행) ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp">

                        <!-- 주 연령대 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="30dp"
                            android:gravity="center_vertical"
                            android:paddingVertical="6dp">
                            <TextView style="@style/SpecLabel" android:text="주 연령대"/>
                            <TextView android:id="@+id/teamAge" style="@style/SpecValue"/>
                        </LinearLayout>

                        <!-- 실력 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="30dp"
                            android:gravity="center_vertical"
                            android:paddingVertical="6dp">
                            <TextView style="@style/SpecLabel" android:text="실력"/>
                            <TextView android:id="@+id/teamSkill" style="@style/SpecValue"/>
                        </LinearLayout>

                        <!-- 활동 지역 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="30dp"
                            android:gravity="center_vertical"
                            android:paddingVertical="6dp">
                            <TextView style="@style/SpecLabel" android:text="활동 지역"/>
                            <TextView android:id="@+id/teamRegion" style="@style/SpecValue"/>
                        </LinearLayout>

                        <!-- 활동 시간 -->
                        <LinearLayout
                            android:id="@+id/activityDayRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="30dp"
                            android:gravity="center_vertical"
                            android:paddingVertical="6dp">
                            <TextView style="@style/SpecLabel" android:text="활동 시간"/>
                            <TextView android:id="@+id/teamActivityDay" style="@style/SpecValue"/>
                        </LinearLayout>

                        <!-- 활동 장소 -->
                        <LinearLayout
                            android:id="@+id/homeStadiumBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingVertical="6dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="30dp"
                                android:gravity="center_vertical">
                                <TextView style="@style/SpecLabel" android:text="활동 장소"/>
                                <TextView
                                    android:id="@+id/teamHomeStadiumName"
                                    style="@style/SpecValue"
                                    android:textStyle="bold"/>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/teamHomeStadiumAddress"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textColor="#6B7280"
                                android:layout_marginStart="70dp"
                                android:textAlignment="viewEnd"
                                android:visibility="gone"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- ── 팀 소개 섹션 ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:padding="10dp"
                        android:background="@drawable/bg_card_light"
                        android:orientation="vertical">

                        <!-- 제목 행 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingBottom="8dp">

                            <View
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1"
                                android:background="#E5E7EB"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="  팀 소개  "
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#6B7280"/>

                            <View
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1"
                                android:background="#E5E7EB"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/teamIntro"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#4B5563"
                            android:gravity="start"
                            android:textAlignment="viewStart"
                            android:maxLines="10"
                            android:ellipsize="end"
                            android:breakStrategy="balanced"
                            android:lineSpacingExtra="2dp"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════════════════════════════════════════════════
                 다가오는 일정 섹션
                 ═══════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp">

                <!-- 섹션 헤더: 아이콘 + 제목 + 전체보기 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_calendar"
                        android:tint="#42A5F5"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="다가오는 일정"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#111827"/>

                    <TextView
                        android:id="@+id/btnSeeAllSchedule"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="일정 전체보기"
                        android:textSize="12sp"
                        android:textColor="@color/primary"
                        android:padding="6dp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- 일정 컨테이너 (카드 또는 빈 메시지가 여기에 표시) -->
                <LinearLayout
                    android:id="@+id/nextScheduleContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp">

                    <include
                        android:id="@+id/nextScheduleCard"
                        layout="@layout/view_next_schedule_card"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 구분선 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="#E0E0E0"/>

            <!-- ═══════════════════════════════════════════════════
                 기록 섹션
                 ═══════════════════════════════════════════════════ -->

            <!-- 섹션 헤더: 아이콘 + 제목 + 전체보기 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_baseline_bar_chart_24"
                    android:tint="#2196F3"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="기록"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#111827"/>

                <TextView
                    android:id="@+id/tvSeeDetails"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="기록 전체보기"
                    android:textSize="12sp"
                    android:textColor="@color/primary"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- 기록 카드 (Capstone 스타일) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeColor="#E8EEF5"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:id="@+id/recordSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- 통계 행: 경기 / 승 / 무 / 패 / 승률 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="5"
                        android:paddingBottom="8dp">

                        <!-- 경기 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="경기"
                                android:textColor="#757575"
                                android:textSize="11sp"/>
                            <TextView
                                android:id="@+id/tvGames"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#000000"
                                android:textStyle="bold"
                                android:textSize="16sp"/>
                        </LinearLayout>

                        <!-- 승 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="승"
                                android:textColor="@color/win"
                                android:textSize="11sp"/>
                            <TextView
                                android:id="@+id/tvWins"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/win"
                                android:textStyle="bold"
                                android:textSize="16sp"/>
                        </LinearLayout>

                        <!-- 무 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="무"
                                android:textColor="@color/draw"
                                android:textSize="11sp"/>
                            <TextView
                                android:id="@+id/tvDraws"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/draw"
                                android:textStyle="bold"
                                android:textSize="16sp"/>
                        </LinearLayout>

                        <!-- 패 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="패"
                                android:textColor="@color/loss"
                                android:textSize="11sp"/>
                            <TextView
                                android:id="@+id/tvLosses"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/loss"
                                android:textStyle="bold"
                                android:textSize="16sp"/>
                        </LinearLayout>

                        <!-- 승률 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="승률"
                                android:textColor="#757575"
                                android:textSize="11sp"/>
                            <TextView
                                android:id="@+id/tvWinRate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textColor="#000000"
                                android:textStyle="bold"
                                android:textSize="16sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 구분선 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EAEAEA"
                        android:layout_marginBottom="8dp"/>

                    <!-- 득점 / 실점 행 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <!-- 득점 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="득점"
                                android:textColor="@color/goal_for"
                                android:textSize="11sp"/>
                            <TextView
                                android:id="@+id/tvGF"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#444444"
                                android:textStyle="bold"
                                android:textSize="13sp"/>
                        </LinearLayout>

                        <!-- 실점 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="실점"
                                android:textColor="@color/goal_against"
                                android:textSize="11sp"/>
                            <TextView
                                android:id="@+id/tvGA"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#444444"
                                android:textStyle="bold"
                                android:textSize="13sp"/>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 구분선 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="#E0E0E0"/>

            <!-- ═══════════════════════════════════════════════════
                 팀 멤버 섹션
                 ═══════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="@dimen/spacing_xl">

                <!-- 섹션 헤더 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_baseline_group_24"
                        android:tint="#2196F3"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/tvMemberTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="팀 멤버 (0)"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#111827"/>
                </LinearLayout>

                <!-- 기존 단일 리스트 컨테이너 (호환용, GONE) -->
                <LinearLayout
                    android:id="@+id/playerListLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"/>

                <!-- 포지션별 멤버 리스트 -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewMembers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:nestedScrollingEnabled="false"/>

                <!-- 하단 버튼 영역 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="@dimen/spacing_lg">

                    <!-- 주장/부주장 전용: 초대 + 팀 정보 수정 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <Button
                            android:id="@+id/btnInvite"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/btn_height"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:text="팀원 초대"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/primary"
                            android:visibility="gone"/>

                        <Button
                            android:id="@+id/btnEditTeam"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/btn_height"
                            android:layout_weight="1"
                            android:text="팀 정보 수정"
                            android:textAllCaps="false"
                            android:textColor="@color/primary"
                            android:backgroundTint="@color/white"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <!-- 가입 신청 목록 (주장/부주장) -->
                    <Button
                        android:id="@+id/btnJoinRequests"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/btn_height"
                        android:layout_marginBottom="@dimen/spacing_sm"
                        android:text="가입 신청 목록"
                        android:textAllCaps="false"
                        android:textColor="@color/primary"
                        android:backgroundTint="@color/primary_light"
                        android:visibility="gone"/>

                    <!-- 팀 탈퇴 (일반 멤버) -->
                    <Button
                        android:id="@+id/btnLeaveTeam"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/btn_height"
                        android:text="팀 탈퇴"
                        android:textAllCaps="false"
                        android:textColor="@color/loss"
                        android:backgroundTint="@color/white"
                        android:visibility="gone"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

