<?xml version="1.0" encoding="utf-8"?>
<com.jjw.soccerclub.common.StateLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/stateLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:loadingLayout="@layout/view_state_loading"
    app:emptyLayout="@layout/view_state_empty"
    android:background="@color/bg_page">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 팀 사진 (클릭 시 변경) -->
            <ImageView
                android:id="@+id/teamPhoto"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:src="@drawable/default_team_photo"
                android:clickable="true"
                android:focusable="true"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/page_padding_horizontal">

                <!-- 팀 로고 + 이름 + 소개 토글 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/spacing_md">

                    <ImageView
                        android:id="@+id/teamLogo"
                        android:layout_width="@dimen/avatar_md"
                        android:layout_height="@dimen/avatar_md"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_shield_gray"/>

                    <TextView
                        android:id="@+id/teamName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:textSize="@dimen/text_xl"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <ImageView
                        android:id="@+id/introToggle"
                        android:layout_width="@dimen/icon_sm"
                        android:layout_height="@dimen/icon_sm"
                        android:src="@drawable/ic_arrow_down"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- 팀 소개 -->
                <TextView
                    android:id="@+id/teamIntro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:textSize="@dimen/text_md"
                    android:textColor="@color/text_secondary"
                    android:maxLines="10"
                    android:ellipsize="end"/>

                <!-- 구분선 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/divider_height"
                    android:background="@color/bg_divider"
                    android:layout_marginVertical="@dimen/spacing_md"/>

                <!-- 팀 정보 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/spacing_xs">
                        <TextView style="@style/SpecLabel" android:text="지역"/>
                        <TextView android:id="@+id/teamRegion" style="@style/SpecValue"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/spacing_xs">
                        <TextView style="@style/SpecLabel" android:text="실력"/>
                        <TextView android:id="@+id/teamSkill" style="@style/SpecValue"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/spacing_xs">
                        <TextView style="@style/SpecLabel" android:text="나이대"/>
                        <TextView android:id="@+id/teamAge" style="@style/SpecValue"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/teamActivityDay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="@dimen/spacing_xs"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/teamHomeStadiumName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="@dimen/spacing_xs"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/teamHomeStadiumAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/text_hint"
                        android:visibility="gone"/>
                </LinearLayout>

                <!-- 구분선 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/divider_height"
                    android:background="@color/bg_divider"
                    android:layout_marginVertical="@dimen/spacing_md"/>

                <!-- 다가오는 일정 -->
                <TextView
                    android:id="@+id/btnSeeAllSchedule"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="일정 전체 보기"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/primary"
                    android:clickable="true"
                    android:focusable="true"/>

                <LinearLayout
                    android:id="@+id/nextScheduleCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="@dimen/card_padding"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone">

                    <View android:id="@+id/scheduleLoading"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:visibility="gone"/>

                    <LinearLayout android:id="@+id/scheduleContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvNextDateChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_sm"
                            android:textColor="@color/primary"
                            android:background="@drawable/bg_filter_chip_selector"
                            android:paddingHorizontal="@dimen/chip_padding_horizontal"
                            android:paddingVertical="@dimen/chip_padding_vertical"
                            android:layout_marginBottom="@dimen/spacing_sm"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/imgHomeLogo"
                                android:layout_width="@dimen/avatar_sm"
                                android:layout_height="@dimen/avatar_sm"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_shield_gray"/>

                            <TextView
                                android:id="@+id/tvHomeName"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="@dimen/spacing_sm"
                                android:textSize="@dimen/text_md"
                                android:textColor="@color/text_primary"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="VS"
                                android:textSize="@dimen/text_sm"
                                android:textColor="@color/text_secondary"
                                android:layout_marginHorizontal="@dimen/spacing_sm"/>

                            <TextView
                                android:id="@+id/tvAwayName"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textSize="@dimen/text_md"
                                android:textColor="@color/text_primary"
                                android:textStyle="bold"
                                android:gravity="end"/>

                            <ImageView
                                android:id="@+id/imgAwayLogo"
                                android:layout_width="@dimen/avatar_sm"
                                android:layout_height="@dimen/avatar_sm"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_shield_gray"
                                android:layout_marginStart="@dimen/spacing_sm"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvPlace"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_sm"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="@dimen/spacing_xs"/>

                        <TextView
                            android:id="@+id/tvAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_sm"
                            android:textColor="@color/text_hint"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/nextScheduleContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>
                </LinearLayout>

                <!-- 구분선 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/divider_height"
                    android:background="@color/bg_divider"
                    android:layout_marginVertical="@dimen/spacing_md"/>

                <!-- 전적 요약 -->
                <LinearLayout
                    android:id="@+id/recordSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="경기" android:textSize="@dimen/text_sm" android:textColor="@color/text_secondary" android:gravity="center"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="승"  android:textSize="@dimen/text_sm" android:textColor="@color/text_secondary" android:gravity="center"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="무"  android:textSize="@dimen/text_sm" android:textColor="@color/text_secondary" android:gravity="center"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="패"  android:textSize="@dimen/text_sm" android:textColor="@color/text_secondary" android:gravity="center"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="득점" android:textSize="@dimen/text_sm" android:textColor="@color/text_secondary" android:gravity="center"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="실점" android:textSize="@dimen/text_sm" android:textColor="@color/text_secondary" android:gravity="center"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="승률" android:textSize="@dimen/text_sm" android:textColor="@color/text_secondary" android:gravity="center"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView android:id="@+id/tvGames"   android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0" android:textSize="@dimen/text_md" android:textColor="@color/text_primary" android:textStyle="bold" android:gravity="center"/>
                        <TextView android:id="@+id/tvWins"    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0" android:textSize="@dimen/text_md" android:textColor="@color/text_primary" android:textStyle="bold" android:gravity="center"/>
                        <TextView android:id="@+id/tvDraws"   android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0" android:textSize="@dimen/text_md" android:textColor="@color/text_primary" android:textStyle="bold" android:gravity="center"/>
                        <TextView android:id="@+id/tvLosses"  android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0" android:textSize="@dimen/text_md" android:textColor="@color/text_primary" android:textStyle="bold" android:gravity="center"/>
                        <TextView android:id="@+id/tvGF"      android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0" android:textSize="@dimen/text_md" android:textColor="@color/text_primary" android:textStyle="bold" android:gravity="center"/>
                        <TextView android:id="@+id/tvGA"      android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0" android:textSize="@dimen/text_md" android:textColor="@color/text_primary" android:textStyle="bold" android:gravity="center"/>
                        <TextView android:id="@+id/tvWinRate" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="-" android:textSize="@dimen/text_md" android:textColor="@color/text_primary" android:textStyle="bold" android:gravity="center"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvSeeDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="전적 상세 보기"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/primary"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- 구분선 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/divider_height"
                    android:background="@color/bg_divider"
                    android:layout_marginVertical="@dimen/spacing_md"/>

                <!-- 멤버 리스트 -->
                <TextView
                    android:id="@+id/tvMemberTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="팀 멤버"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_lg"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="@dimen/spacing_sm"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewMembers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:nestedScrollingEnabled="false"/>

                <!-- 하단 버튼 영역 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:layout_marginBottom="@dimen/spacing_xl">

                    <!-- 주장/부주장 전용: 초대 + 팀 정보 수정 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <Button
                            android:id="@+id/btnInvite"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/btn_height"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:text="팀원 초대"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/primary"
                            android:visibility="gone"
                            app:cornerRadius="@dimen/btn_radius"/>

                        <!-- ✅ 팀 정보 수정 버튼 (주장/부주장에게만 표시) -->
                        <Button
                            android:id="@+id/btnEditTeam"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/btn_height"
                            android:layout_weight="1"
                            android:text="팀 정보 수정"
                            android:textAllCaps="false"
                            android:textColor="@color/primary"
                            android:backgroundTint="@color/bg_surface"
                            android:visibility="gone"
                            app:strokeColor="@color/primary"
                            app:strokeWidth="1dp"
                            app:cornerRadius="@dimen/btn_radius"/>
                    </LinearLayout>

                    <!-- ✅ 가입 신청 목록 버튼 (주장/부주장에게만 표시) -->
                    <Button
                        android:id="@+id/btnJoinRequests"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/btn_height"
                        android:layout_marginBottom="@dimen/spacing_sm"
                        android:text="가입 신청 목록"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/primary"
                        android:visibility="gone"
                        app:cornerRadius="@dimen/btn_radius"/>

                    <!-- 팀 탈퇴 (전체 멤버) -->
                    <Button
                        android:id="@+id/btnLeaveTeam"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/btn_height"
                        android:text="팀 탈퇴"
                        android:textAllCaps="false"
                        android:textColor="@color/loss"
                        android:backgroundTint="@color/bg_surface"
                        app:strokeColor="@color/loss"
                        app:strokeWidth="1dp"
                        app:cornerRadius="@dimen/btn_radius"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/playerListLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</com.jjw.soccerclub.common.StateLayout>