<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8EFF8"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/page_padding_horizontal"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_lg">

        <!-- ★ 날짜 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_light"
            android:padding="12dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_calendar"
                    android:tint="#42A5F5"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="경기 날짜"
                    android:textSize="15sp"
                    android:textColor="#111111"
                    android:layout_marginStart="8dp"/>

                <TextView
                    android:id="@+id/txtDate"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:hint="날짜 선택"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:background="@drawable/bg_field_tap"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ★ 시간 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_light"
            android:padding="12dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_clock"
                    android:tint="#42A5F5"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="경기 시간"
                    android:textSize="15sp"
                    android:textColor="#111111"
                    android:layout_marginStart="8dp"/>

                <TextView
                    android:id="@+id/txtTime"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:hint="시간 선택"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:background="@drawable/bg_field_tap"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ★ 시합 장소 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_light"
            android:padding="12dp"
            android:layout_marginBottom="10dp">

            <!-- 장소 아이콘 + 입력 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_location_pin"
                    android:tint="#42A5F5"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="시합 장소"
                    android:textSize="15sp"
                    android:textColor="#111111"
                    android:layout_marginStart="8dp"/>

                <EditText
                    android:id="@+id/editStadium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:hint="구장명 입력"
                    android:background="@android:color/transparent"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:paddingBottom="4dp"/>
            </LinearLayout>

            <!-- 주소 검색 버튼 -->
            <TextView
                android:id="@+id/txtAddressSearch"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:minWidth="72dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center_vertical"
                android:text="주소 검색"
                android:textColor="#1E88E5"
                android:textSize="13sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_chip_outline_blue"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"/>

            <!-- 선택된 주소 표시 -->
            <TextView
                android:id="@+id/txtSelectedAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_field_readonly"
                android:padding="10dp"
                android:text="주소가 선택되지 않았습니다."
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_sm"/>
        </LinearLayout>

        <!-- ★ 상세 내용 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_light"
            android:padding="12dp"
            android:layout_marginBottom="@dimen/spacing_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_notes"
                    android:tint="#42A5F5"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="상세 내용"
                    android:textSize="15sp"
                    android:textColor="#111111"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <EditText
                android:id="@+id/editDetails"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:hint="시합 관련 상세 내용을 입력해 주세요"
                android:gravity="top"
                android:padding="12dp"
                android:background="@drawable/bg_multiline"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp"
                android:inputType="textMultiLine"/>
        </LinearLayout>

        <!-- ★ 등록 버튼 (스크롤 내부) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="@dimen/btn_height"
            android:text="시합 모집글 등록"
            android:textColor="@color/white"
            android:textAllCaps="false"
            app:backgroundTint="@color/primary"
            app:cornerRadius="@dimen/btn_radius"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>