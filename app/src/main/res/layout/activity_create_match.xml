<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/page_padding_horizontal">

        <!-- 날짜 -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="경기 날짜" android:textSize="@dimen/text_sm"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="@dimen/spacing_lg"/>

        <TextView android:id="@+id/txtDate"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:background="@drawable/bg_input"
            android:padding="@dimen/input_padding_horizontal"
            android:hint="날짜 선택" android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:clickable="true" android:focusable="true"/>

        <!-- 시간 -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="경기 시간" android:textSize="@dimen/text_sm"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="@dimen/spacing_md"/>

        <TextView android:id="@+id/txtTime"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:background="@drawable/bg_input"
            android:padding="@dimen/input_padding_horizontal"
            android:hint="시간 선택" android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:clickable="true" android:focusable="true"/>

        <!-- 시합 장소 -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="시합 장소" android:textSize="@dimen/text_sm"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="@dimen/spacing_md"/>

        <EditText android:id="@+id/editStadium"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:background="@drawable/bg_input"
            android:hint="구장명 입력" android:inputType="text"
            android:padding="@dimen/input_padding_horizontal"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginTop="@dimen/spacing_xs">

            <TextView android:id="@+id/txtSelectedAddress"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/text_sm" android:textColor="@color/text_hint"
                android:text="주소가 선택되지 않았습니다."/>

            <TextView android:id="@+id/txtAddressSearch"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="주소 검색" android:textColor="@color/primary"
                android:textSize="@dimen/text_sm"
                android:clickable="true" android:focusable="true"
                android:layout_marginStart="@dimen/spacing_sm"/>
        </LinearLayout>

        <!-- 구분선 -->
        <View android:layout_width="match_parent" android:layout_height="@dimen/divider_height"
            android:background="@color/bg_divider"
            android:layout_marginVertical="@dimen/spacing_md"/>

        <!-- 상세 내용 -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="상세 내용" android:textSize="@dimen/text_sm"
            android:textColor="@color/text_secondary"/>

        <EditText android:id="@+id/editDetails"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:background="@drawable/bg_input"
            android:gravity="top" android:hint="시합 관련 상세 내용을 입력해 주세요"
            android:inputType="textMultiLine" android:minLines="4"
            android:padding="@dimen/input_padding_horizontal"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"/>

        <!-- 등록 버튼 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent" android:layout_height="@dimen/btn_height"
            android:layout_marginTop="@dimen/spacing_xl"
            android:layout_marginBottom="@dimen/spacing_xl"
            android:text="시합 모집글 등록"
            android:textColor="@color/white" android:textAllCaps="false"
            app:backgroundTint="@color/primary"
            app:cornerRadius="@dimen/btn_radius"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>