<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_marginHorizontal="@dimen/spacing_sm"
    android:layout_marginBottom="@dimen/spacing_sm">

    <!-- ★ 선택 모드 체크박스 (기본 GONE) -->
    <CheckBox
        android:id="@+id/cbSelect"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="4dp"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/bg_card">

        <include android:id="@+id/includePost" layout="@layout/recruit_post_item"/>

        <LinearLayout
            android:id="@+id/includeToggleHeader"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/spacing_md"
            android:background="@color/bg_section"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/textApplicantCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="@dimen/text_sm"
                android:textColor="@color/text_primary"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="명 신청"
                android:textSize="@dimen/text_sm"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="2dp"/>

            <TextView
                android:id="@+id/textApplicantNew"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEW"
                android:textSize="@dimen/text_xs"
                android:textColor="@color/white"
                android:background="@drawable/bg_badge_red_circle"
                android:paddingHorizontal="@dimen/spacing_xs"
                android:layout_marginStart="@dimen/spacing_sm"
                android:visibility="gone"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <ImageView
                android:id="@+id/iconToggleArrow"
                android:layout_width="@dimen/icon_sm"
                android:layout_height="@dimen/icon_sm"
                android:src="@drawable/ic_arrow_down"
                android:contentDescription="펼치기"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/applicantsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"/>

    </LinearLayout>

</LinearLayout>