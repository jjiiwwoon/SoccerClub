<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_surface"/>
            <corners android:radius="@dimen/input_radius"/>
            <stroke android:width="@dimen/input_stroke_focused" android:color="@color/input_border_focused"/>
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_surface"/>
            <corners android:radius="@dimen/input_radius"/>
            <stroke android:width="@dimen/input_stroke_focused" android:color="@color/input_border_focused"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_surface"/>
            <corners android:radius="@dimen/input_radius"/>
            <stroke android:width="@dimen/input_stroke_width" android:color="@color/input_border_default"/>
        </shape>
    </item>
</selector>
